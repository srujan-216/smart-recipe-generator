# Server Configuration
PORT=5000
NODE_ENV=development

# Database (Local MongoDB)
MONGO_URI=mongodb://127.0.0.1:27017/smart_recipe_db

# Database (MongoDB Atlas - uncomment to use cloud)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/smart_recipe_db?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Groq AI API
GROQ_API_KEY=your_groq_api_key_here

# Email Configuration (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-not-regular-password
EMAIL_FROM=noreply@smartrecipes.com

# Frontend URL
CLIENT_URL=http://localhost:5000

# App Settings
APP_NAME=Smart Recipe Generator
APP_VERSION=1.0.0
